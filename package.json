    "next-mdx-remote": "^6.0.0",
    "nodemailer": "^9.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.20",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "image-size": "^2.0.2",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "sharp": "^0.35.2",
    "tailwindcss": "^4.3.1"
